---
const faqs = [
  {
    question: "Is The Anthropic Stack only about Anthropic and Claude?",
    answer:
      "No. The name reflects where the newsletter started, but coverage spans the full AI landscape. Claude, ChatGPT, Gemini, open source models, automation tools, MCP servers and everything in between. If it matters to people building with AI, it belongs here.",
  },
  {
    question: "How often do you publish?",
    answer:
      "Three times a week. Monday, Wednesday and Friday. Each issue takes under five minutes to read.",
  },
  {
    question: "Is it free?",
    answer:
      "Yes. The core newsletter is free and always will be. A paid tier with deeper analysis and exclusive content is planned for later in 2026.",
  },
  {
    question: "What makes this different from other AI newsletters?",
    answer:
      "Specificity. Most AI newsletters cover announcements. The Anthropic Stack covers what works. Every issue is written by someone who builds production AI systems daily. The perspective is practical, opinionated and grounded in real usage.",
  },
  {
    question: "Can I sponsor The Anthropic Stack?",
    answer:
      'Yes. Sponsorship opportunities open from month four. Reach out to <a href="mailto:theanthropicstack@proton.me" class="text-accent hover:opacity-80 transition-opacity">theanthropicstack@proton.me</a> for the media kit.',
  },
];
---

<section class="py-28 md:py-36 relative z-1">
  <div class="mx-auto max-w-[720px] px-6 md:px-10">
    <div class="reveal">
      <p class="font-mono text-[11px] font-medium text-accent uppercase tracking-[0.25em] mb-5">
        Frequently asked questions
      </p>
      <h2 class="font-display text-[clamp(32px,5vw,56px)] font-medium tracking-tight leading-[1.1] mb-14">
        Got questions?
      </h2>
    </div>

    <div class="space-y-2">
      {
        faqs.map((faq) => (
          <details class="faq-item reveal-child group">
            <summary class="flex items-start justify-between gap-4 px-0 py-6 cursor-pointer list-none text-[16px] font-body font-normal select-none border-b border-border transition-colors duration-300 hover:border-border-warm">
              <span class="text-text-warm group-hover:text-text transition-colors duration-300">{faq.question}</span>
              <div class="w-6 h-6 rounded-full border border-border-warm flex items-center justify-center shrink-0 mt-0.5 transition-all duration-300 group-hover:border-accent group-open:bg-accent group-open:border-accent">
                <svg
                  class="w-3 h-3 stroke-text-tertiary transition-all duration-300 group-open:stroke-white group-open:rotate-45 group-hover:stroke-accent"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke-width="2"
                  stroke-linecap="round"
                >
                  <line x1="12" y1="5" x2="12" y2="19" />
                  <line x1="5" y1="12" x2="19" y2="12" />
                </svg>
              </div>
            </summary>
            <div class="pb-6 text-text-secondary text-[15px] leading-[1.8] font-light pr-10">
              <p set:html={faq.answer} />
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  details summary::-webkit-details-marker {
    display: none;
  }
</style>
