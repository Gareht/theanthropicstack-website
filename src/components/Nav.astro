<!-- Minimal editorial navigation -->
<nav id="main-nav" class="fixed top-[2px] left-0 right-0 z-100 transition-all duration-500">
  <div class="mx-auto max-w-[1200px] px-6 md:px-10 py-5 flex items-center justify-between">
    <!-- Logo: wordmark style -->
    <a href="/" class="flex items-center gap-3 group no-underline">
      <svg class="h-7 w-auto shrink-0 transition-transform duration-300 group-hover:rotate-12" viewBox="0 0 64 84" fill="none" aria-hidden="true">
        <path d="M12 62 L32 50 L52 62 L32 74Z" fill="currentColor" />
        <path d="M12 62 L32 74 L32 80 L12 68Z" fill="#e8713a" />
        <path d="M32 74 L52 62 L52 68 L32 80Z" fill="currentColor" />
        <path d="M12 44 L32 32 L52 44 L32 56Z" fill="#e8713a" />
        <path d="M12 26 L32 14 L52 26 L32 38Z" stroke="currentColor" stroke-width="4" stroke-linejoin="round" />
        <path d="M22 26 L32 20 L42 26 L32 32Z" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round" />
        <path d="M47 2l1.2 4.3 4.3 1.2-4.3 1.2L47 13l-1.2-4.3-4.3-1.2 4.3-1.2Z" fill="currentColor" />
      </svg>
      <span class="font-display text-[22px] font-medium text-text tracking-tight">
        The Anthropic Stack
      </span>
    </a>

    <!-- Subscribe CTA -->
    <a
      href="https://theanthropicstack.substack.com"
      target="_blank"
      rel="noopener"
      class="nav-cta group relative inline-flex items-center gap-2 px-5 py-2.5 text-sm font-body font-medium tracking-wide no-underline overflow-hidden rounded-lg transition-all duration-300"
    >
      <span class="relative z-10 text-text">Subscribe</span>
      <svg class="relative z-10 w-4 h-4 stroke-text transition-transform duration-300 group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14M12 5l7 7-7 7" />
      </svg>
    </a>
  </div>
</nav>

<style>
  .nav-cta {
    background: var(--color-bg-warm);
    border: 1px solid var(--color-border-warm);
  }

  .nav-cta:hover {
    border-color: var(--color-accent);
    background: var(--color-accent-subtle);
  }

  nav.scrolled {
    background: oklch(0.1 0.01 30 / 0.85);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
  }
</style>

<script>
  const nav = document.getElementById("main-nav");
  let scrolled = false;

  window.addEventListener(
    "scroll",
    () => {
      const shouldBeScrolled = window.scrollY > 60;
      if (shouldBeScrolled !== scrolled) {
        scrolled = shouldBeScrolled;
        nav?.classList.toggle("scrolled", scrolled);
      }
    },
    { passive: true }
  );

</script>
