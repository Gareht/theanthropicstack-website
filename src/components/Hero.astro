---
import SubscribeForm from "./SubscribeForm.astro";
---

<section class="relative min-h-screen flex items-center pt-28 pb-24 overflow-hidden" id="subscribe">
  <!-- Dramatic radial glow behind headline -->
  <div
    class="absolute top-[10%] left-1/2 -translate-x-1/2 w-[900px] h-[600px] pointer-events-none"
    style="background: radial-gradient(ellipse at center, oklch(0.68 0.17 45 / 0.07) 0%, transparent 60%);"
    aria-hidden="true"
  ></div>

  <div class="relative z-1 mx-auto max-w-[1200px] px-6 md:px-10 w-full">
    <div class="max-w-[900px] mx-auto text-center">
      <!-- Mono label -->
      <p class="font-mono text-[11px] font-medium text-accent uppercase tracking-[0.25em] mb-8 opacity-0 animate-[fade-up_0.6s_0.1s_var(--ease-out-expo)_forwards]">
        AI Newsletter &middot; Three Issues Per Week
      </p>

      <!-- Headline -->
      <h1
        id="hero-headline"
        class="hero-headline font-display font-semibold leading-[1.05] mb-8 text-[clamp(48px,8vw,96px)] tracking-[-0.02em]"
      ></h1>

      <!-- Subheadline (speakable) -->
      <p class="hero-sub text-[clamp(17px,2vw,21px)] text-text-secondary max-w-[580px] mx-auto mb-5 leading-relaxed font-light opacity-0 animate-[fade-up_0.7s_1.6s_var(--ease-out-expo)_forwards]">
        Three issues a week. Real tools. Real workflows. No hype.
      </p>

      <!-- Extended description (speakable) -->
      <p class="hero-desc text-[15px] text-text-tertiary max-w-[520px] mx-auto mb-12 leading-[1.8] font-light opacity-0 animate-[fade-up_0.7s_1.8s_var(--ease-out-expo)_forwards]">
        Every Monday, Wednesday and Friday, The Anthropic Stack delivers the signal
        that matters from the AI developer ecosystem. Claude Code, MCP servers, AI agents,
        automation workflows and the tools reshaping how work gets done.
      </p>

      <!-- Subscribe form -->
      <div class="opacity-0 animate-[fade-up_0.7s_2s_var(--ease-out-expo)_forwards]">
        <SubscribeForm id="hero-form" variant="hero" class="flex justify-center" />
      </div>

      <!-- Social proof -->
      <div class="flex items-center justify-center gap-4 mt-8 opacity-0 animate-[fade-up_0.7s_2.2s_var(--ease-out-expo)_forwards]">
        <div class="flex">
          <span class="w-6 h-6 rounded-full border-[1.5px] border-bg inline-flex items-center justify-center text-[10px] font-medium bg-stone-700 text-stone-300">G</span>
          <span class="w-6 h-6 rounded-full border-[1.5px] border-bg inline-flex items-center justify-center text-[10px] font-medium -ml-1.5 bg-stone-600 text-stone-300">A</span>
          <span class="w-6 h-6 rounded-full border-[1.5px] border-bg inline-flex items-center justify-center text-[10px] font-medium -ml-1.5 bg-stone-700 text-stone-300">M</span>
          <span class="w-6 h-6 rounded-full border-[1.5px] border-bg inline-flex items-center justify-center text-[10px] font-medium -ml-1.5 bg-stone-600 text-stone-300">J</span>
          <span class="w-6 h-6 rounded-full border-[1.5px] border-bg inline-flex items-center justify-center text-[10px] font-medium -ml-1.5 bg-accent/80 text-white">S</span>
        </div>
        <span class="text-text-tertiary text-[13px] font-light tracking-wide">
          Subscribe free &middot; Under 5 minutes to read
        </span>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-0 animate-[fade-up_0.7s_2.5s_var(--ease-out-expo)_forwards]">
    <span class="text-text-tertiary text-[11px] font-mono tracking-widest uppercase">Scroll</span>
    <div class="w-[1px] h-8 bg-gradient-to-b from-text-tertiary to-transparent"></div>
  </div>
</section>

<style>
  .hero-headline :global(.word) {
    display: inline-block;
    white-space: nowrap;
  }

  .hero-headline :global(.char) {
    display: inline-block;
    opacity: 0;
    transform: translateY(24px);
    animation: char-reveal 0.5s var(--ease-out-expo) forwards;
  }

  .hero-headline :global(.actually) {
    color: var(--color-accent);
    position: relative;
    font-style: italic;
  }

  .hero-headline :global(.actually .char) {
    color: var(--color-accent);
  }

  /* Hand-drawn underline effect */
  .hero-headline :global(.actually::after) {
    content: "";
    position: absolute;
    bottom: 2px;
    left: -2px;
    right: -2px;
    height: 3px;
    background: var(--color-accent);
    border-radius: 2px;
    transform: scaleX(0);
    transform-origin: left;
    animation: draw-underline 0.6s 1.4s var(--ease-out-expo) forwards;
    opacity: 0.7;
  }
</style>

<script>
  const el = document.getElementById("hero-headline");
  if (el) {
    const tokens = [
      { text: "The", cls: "" },
      { text: "AI", cls: "" },
      { text: "newsletter", cls: "" },
      { text: "for", cls: "" },
      { text: "people", cls: "" },
      { text: "who", cls: "" },
      { text: "actually", cls: "actually" },
      { text: "use", cls: "" },
      { text: "it.", cls: "" },
    ];

    let charIndex = 0;
    tokens.forEach((token, ti) => {
      if (ti > 0) el.appendChild(document.createTextNode(" "));

      const wordSpan = document.createElement("span");
      wordSpan.className = `word${token.cls ? ` ${token.cls}` : ""}`;

      for (const char of token.text) {
        const c = document.createElement("span");
        c.className = "char";
        c.textContent = char;
        c.style.animationDelay = `${400 + charIndex * 35}ms`;
        wordSpan.appendChild(c);
        charIndex++;
      }

      el.appendChild(wordSpan);
    });
  }
</script>
