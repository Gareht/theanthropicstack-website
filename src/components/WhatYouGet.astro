---
const cards = [
  {
    day: "Mon",
    title: "The Signal",
    description:
      "The biggest AI story of the week, explained properly. What happened, why it matters and what to do about it. Plus a curated stack of the most important developments across the ecosystem.",
    icon: `<path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" />`,
    featured: true,
  },
  {
    day: "Wed",
    title: "The Build",
    description:
      "Hands-on. Step-by-step build guides, prompts that actually work, honest tool reviews and before-and-after workflow transformations. Every issue is designed to finish in under 30 minutes.",
    icon: `<rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/>`,
    featured: false,
  },
  {
    day: "Fri",
    title: "The Queue",
    description:
      "Five links worth your weekend. The best writing, tools and conversations from across the AI landscape, each with context on why it deserves your attention.",
    icon: `<path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20" />`,
    featured: false,
  },
];
---

<section class="py-28 md:py-36 relative z-1">
  <div class="mx-auto max-w-[1200px] px-6 md:px-10">
    <div class="reveal mb-20">
      <p class="font-mono text-[11px] font-medium text-accent uppercase tracking-[0.25em] mb-5">
        What you get
      </p>
      <h2 class="font-display text-[clamp(32px,5vw,56px)] font-medium tracking-tight leading-[1.1]">
        Three issues.<br />
        <span class="text-text-secondary">Every week.</span>
      </h2>
    </div>

    <!-- Magazine-style asymmetric grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-5">
      {/* Featured card: Monday */}
      <div class="lg:col-span-5 reveal-child">
        <div class="feature-card group relative h-full rounded-2xl border border-border p-10 transition-all duration-500 overflow-hidden">
          <!-- Accent glow on hover -->
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none" style="background: radial-gradient(ellipse at 30% 20%, oklch(0.68 0.17 45 / 0.06), transparent 60%);"></div>

          <div class="relative z-1">
            <div class="flex items-center gap-3 mb-8">
              <div class="w-10 h-10 rounded-lg bg-accent-muted flex items-center justify-center">
                <svg class="w-5 h-5 stroke-accent fill-none" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" />
                </svg>
              </div>
              <span class="font-mono text-[11px] text-accent uppercase tracking-[0.2em]">Monday</span>
            </div>
            <h3 class="font-display text-[32px] font-medium tracking-tight mb-4 leading-tight">The Signal</h3>
            <p class="text-text-secondary text-[15px] leading-[1.8] font-light">{cards[0].description}</p>
          </div>
        </div>
      </div>

      {/* Stacked cards: Wednesday + Friday */}
      <div class="lg:col-span-7 flex flex-col gap-5">
        {cards.slice(1).map((card) => (
          <div class="reveal-child">
            <div class="side-card group relative rounded-2xl border border-border p-8 transition-all duration-500 overflow-hidden">
              <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none" style="background: radial-gradient(ellipse at 70% 50%, oklch(0.68 0.17 45 / 0.04), transparent 60%);"></div>

              <div class="relative z-1 flex flex-col sm:flex-row sm:items-start gap-6">
                <div class="flex items-center gap-3 sm:flex-col sm:items-center sm:gap-2 shrink-0">
                  <div class="w-10 h-10 rounded-lg bg-accent-muted flex items-center justify-center">
                    <svg class="w-5 h-5 stroke-accent fill-none" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={card.icon} />
                  </div>
                  <span class="font-mono text-[11px] text-accent uppercase tracking-[0.2em]">{card.day}</span>
                </div>
                <div>
                  <h3 class="font-display text-[26px] font-medium tracking-tight mb-3 leading-tight">{card.title}</h3>
                  <p class="text-text-secondary text-[15px] leading-[1.8] font-light">{card.description}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .feature-card,
  .side-card {
    background: var(--color-bg-warm);
  }

  .feature-card:hover,
  .side-card:hover {
    border-color: var(--color-border-warm);
    transform: translateY(-2px);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
  }
</style>
