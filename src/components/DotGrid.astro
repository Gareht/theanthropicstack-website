<!-- Warm ambient gradient that follows the mouse — replaces the dot grid -->
<div id="ambient-glow" class="fixed inset-0 pointer-events-none z-0" aria-hidden="true"></div>

<!-- Top accent bar (newspaper masthead feel) -->
<div class="fixed top-0 left-0 right-0 h-[2px] bg-accent z-[101]" aria-hidden="true"></div>

<style>
  #ambient-glow {
    background:
      radial-gradient(ellipse 80% 50% at 50% 0%, oklch(0.68 0.17 45 / 0.04) 0%, transparent 60%),
      radial-gradient(ellipse 50% 80% at 80% 50%, oklch(0.3 0.05 250 / 0.06) 0%, transparent 50%);
  }

  #ambient-glow::after {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      800px circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
      oklch(0.68 0.17 45 / 0.03),
      transparent 60%
    );
    transition: background 0.3s;
  }
</style>

<script>
  const glow = document.getElementById("ambient-glow");
  let ticking = false;

  document.addEventListener("mousemove", (e: MouseEvent) => {
    if (!ticking) {
      requestAnimationFrame(() => {
        glow?.style.setProperty("--mouse-x", `${e.clientX}px`);
        glow?.style.setProperty("--mouse-y", `${e.clientY}px`);
        ticking = false;
      });
      ticking = true;
    }
  });
</script>
