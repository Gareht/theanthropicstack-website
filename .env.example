# Copy to .env and fill in. .env is gitignored and must never be committed.
#
#   cp .env.example .env
#
# Use a NEW password. The one shared in chat is compromised and should be
# rotated in Krystal regardless of whether it is used here.

# Krystal FTP host. Prefer the FTPS-capable hostname.
FTP_HOST=ftp.theanthropicstack.com

# FTP username.
FTP_USER=gaz@theanthropicstack.com

# FTP password. Never commit this. Never paste it into a chat.
FTP_PASS=

# Absolute path to the web root on the server.
# Krystal is usually /public_html. Verify before the first real upload.
FTP_REMOTE_DIR=/public_html
