# Copy to .env and fill in. .env is gitignored and must never be committed.
#
#   cp .env.example .env
#
# Use a NEW password. The one shared in chat is compromised and should be
# rotated in Krystal regardless of whether it is used here.

# Krystal FTP host. Must be the hostname on the server's TLS certificate, which
# is the shared Krystal box, not the site domain. ftp.theanthropicstack.com
# resolves but its certificate names adama-lon.krystal.uk, so verification fails.
FTP_HOST=adama-lon.krystal.uk

# FTP username.
FTP_USER=gaz@theanthropicstack.com

# FTP password. Never commit this. Never paste it into a chat.
FTP_PASS=

# Path to the web root. This FTP account logs straight into the web root, so
# this is "/". It is not /public_html: that would create a nested folder.
FTP_REMOTE_DIR=/
